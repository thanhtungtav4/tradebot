# App
APP_ENV=local
APP_SECRET_KEY=CHANGE_ME_random_32_chars_min
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC

# Datastores (match docker-compose.yml)
DATABASE_URL=postgresql+psycopg://tradebot:tradebot@localhost:5432/tradebot
REDIS_URL=redis://localhost:6379/0

# Admin auth
ADMIN_AUTH_MODE=api_key
ADMIN_API_KEY=CHANGE_ME_random_32_chars_min
ADMIN_CONSOLE_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=CHANGE_ME_argon2_or_bcrypt_hash
ADMIN_SESSION_SECRET=CHANGE_ME_random_32_chars_min
ADMIN_SESSION_TTL_HOURS=8

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME_123:abc
TELEGRAM_SEND_TIMEOUT_SECONDS=10
TELEGRAM_HEALTH_CACHE_SECONDS=300

# TradingView webhook (seed hashes these into data_sources)
TRADINGVIEW_WEBHOOK_TOKEN=CHANGE_ME_random_32_chars_min
TRADINGVIEW_BODY_SECRET=CHANGE_ME_random_32_chars_min
TRADINGVIEW_ALLOWED_IPS=

# Outbox / retry / duplicate
OUTBOX_LOCK_TIMEOUT_SECONDS=120
RETRY_SCAN_INTERVAL_SECONDS=20
DUPLICATE_LOCK_TTL_SECONDS=60

# Feed staleness
STALE_GRACE_MINUTES=20
FUTURE_CANDLE_BUFFER_SECONDS=120

# Retention
CANDLE_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=365

# Future webhook (MT4/MT5)
MTX_WEBHOOK_SECRET=
WEBHOOK_FUTURE_ALLOWED_SKEW_SECONDS=300
